{
  "id": 106,
  "name": "سُورَةُ قُرَيۡشٍ",
  "englishName": "Quraish",
  "englishNameTranslation": "Quraysh",
  "revelationType": "Meccan",
  "numberOfAyahs": 4,
  "ayahs": [
    {
      "number": 1,
      "arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لِإِيلَٰفِ قُرَيْشٍ"
    },
    {
      "number": 2,
      "arabic": "إِۦلَٰفِهِمْ رِحْلَةَ ٱلشِّتَآءِ وَٱلصَّيْفِ"
    },
    {
      "number": 3,
      "arabic": "فَلْيَعْبُدُوا۟ رَبَّ هَٰذَا ٱلْبَيْتِ"
    },
    {
      "number": 4,
      "arabic": "ٱلَّذِىٓ أَطْعَمَهُم مِّن جُوعٍۢ وَءَامَنَهُم مِّنْ خَوْفٍۭ"
    }
  ]
}