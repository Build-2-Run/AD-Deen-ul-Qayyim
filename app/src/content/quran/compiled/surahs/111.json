{
  "id": 111,
  "name": "سُورَةُ المَسَدِ",
  "englishName": "Al-Masad",
  "englishNameTranslation": "The Palm Fibre",
  "revelationType": "Meccan",
  "numberOfAyahs": 5,
  "ayahs": [
    {
      "number": 1,
      "arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ تَبَّتْ يَدَآ أَبِى لَهَبٍۢ وَتَبَّ"
    },
    {
      "number": 2,
      "arabic": "مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ"
    },
    {
      "number": 3,
      "arabic": "سَيَصْلَىٰ نَارًۭا ذَاتَ لَهَبٍۢ"
    },
    {
      "number": 4,
      "arabic": "وَٱمْرَأَتُهُۥ حَمَّالَةَ ٱلْحَطَبِ"
    },
    {
      "number": 5,
      "arabic": "فِى جِيدِهَا حَبْلٌۭ مِّن مَّسَدٍۭ"
    }
  ]
}